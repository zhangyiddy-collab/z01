<view class="page">
  <view wx:if="{{checkout}}" class="checkout-tip">正在结算 {{productIds.length}} 件商品，请选择地址并填写备注</view>
  <block wx:for="{{list}}" wx:key="id">
    <view class="address {{checkout && selectedAddressId == item.id ? 'selected' : ''}}" data-id="{{item.id}}" bindtap="selectAddress">
      <view class="top">{{item.name}} {{item.phone}}</view>
      <view class="muted">{{item.communityName}} {{item.buildingNo}}栋 {{item.unitNo}}单元 {{item.roomNo}}</view>
      <view class="actions">
        <view wx:if="{{checkout && selectedAddressId == item.id}}" class="selected-badge">已选择</view>
        <view class="delete" data-id="{{item.id}}" catchtap="remove">删除</view>
      </view>
    </view>
  </block>
  <view wx:if="{{checkout}}" class="remark-card">
    <view class="remark-title">配送备注</view>
    <textarea
      class="remark-input"
      value="{{remark}}"
      maxlength="120"
      placeholder="如：放门口、到楼下电话、不要按门铃"
      bindinput="onRemarkInput"
    />
    <view class="select" bindtap="submitCheckout">{{submitting ? '结算中...' : '确认地址并结算'}}</view>
  </view>
  <view class="primary-btn" bindtap="add">新增地址</view>
</view>
