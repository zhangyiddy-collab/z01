<view class="page" wx:if="{{order}}">
  <view class="panel">
    <view class="status">{{order.statusText}}</view>
    <view class="muted">订单号 {{order.orderNo}}</view>
  </view>
  <block wx:for="{{order.items}}" wx:key="id">
    <view class="item">
      <image src="{{item.productCoverUrl}}" mode="aspectFill" />
      <view class="info">
        <view>{{item.productName}}</view>
        <view class="muted">x {{item.quantity}}</view>
      </view>
      <view class="price">¥{{item.totalText}}</view>
    </view>
  </block>
  <view class="panel row">
    <text>应付金额</text>
    <text class="price">¥{{order.amountText}}</text>
  </view>
  <view wx:if="{{order.remark}}" class="panel">
    <view class="muted">订单备注</view>
    <view>{{order.remark}}</view>
  </view>
  <view class="actions">
    <view wx:if="{{order.status === 'PENDING_PAYMENT'}}" class="primary-btn action-btn" bindtap="pay">微信支付</view>
    <view class="delete-btn action-btn" bindtap="remove">删除订单</view>
  </view>
</view>
