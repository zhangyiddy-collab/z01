.panel, .item {
  padding: 24rpx;
  margin-bottom: 18rpx;
  background: #fff;
  border-radius: 16rpx;
}
.status {
  color: #22c55e;
  font-size: 36rpx;
  font-weight: 800;
}
.item {
  display: flex;
  gap: 18rpx;
  align-items: center;
}
.item image {
  width: 128rpx;
  height: 128rpx;
  border-radius: 12rpx;
}
.info {
  flex: 1;
}
.row {
  display: flex;
  justify-content: space-between;
}
.actions {
  display: flex;
  gap: 16rpx;
}
.action-btn {
  flex: 1;
}
.delete-btn {
  height: 88rpx;
  border-radius: 16rpx;
  background: #fee2e2;
  color: #dc2626;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
