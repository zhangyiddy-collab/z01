.card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  margin-bottom: 22rpx;
  background: #fff;
  border-radius: 16rpx;
}
.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: #22c55e;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
}
.name {
  font-size: 34rpx;
  font-weight: 800;
}
.menu {
  margin-top: 20rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
}

