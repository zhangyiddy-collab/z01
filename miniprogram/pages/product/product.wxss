.hero {
  width: 100%;
  height: 560rpx;
  border-radius: 18rpx;
  background: #e5e7eb;
}
.panel {
  margin-top: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}
.name {
  font-size: 38rpx;
  font-weight: 800;
}
.subtitle, .desc {
  margin-top: 14rpx;
  color: #64748b;
}
.price {
  margin-top: 20rpx;
  color: #ef4444;
  font-size: 42rpx;
  font-weight: 800;
}
.bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 24rpx 40rpx;
  background: #fff;
}
.stepper {
  width: 220rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
}
.cart {
  flex: 1;
}
.buy {
  flex: 1;
  background: #ef4444;
}
