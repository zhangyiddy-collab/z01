.order {
  padding: 24rpx;
  margin-bottom: 18rpx;
  background: #fff;
  border-radius: 16rpx;
}
.row {
  display: flex;
  justify-content: space-between;
  color: #64748b;
}
.status {
  color: #22c55e;
}
.amount {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 800;
}
.actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 18rpx;
}
.delete {
  width: 92rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 12rpx;
  background: #fee2e2;
  color: #dc2626;
  font-size: 24rpx;
}
.empty {
  padding: 160rpx 0;
  color: #94a3b8;
  text-align: center;
}
