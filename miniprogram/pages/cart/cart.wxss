.item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  margin-bottom: 18rpx;
  background: #fff;
  border-radius: 16rpx;
}
.item image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
}
.info {
  flex: 1;
}
.name {
  font-weight: 700;
}
.settle {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 116rpx;
  padding: 18rpx 24rpx 36rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.btn {
  width: 220rpx;
}
.delete {
  width: 92rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 12rpx;
  background: #fee2e2;
  color: #dc2626;
  font-size: 24rpx;
}
.empty {
  padding: 160rpx 0;
  color: #94a3b8;
  text-align: center;
}
